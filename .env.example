# ─── Tavern operation mode ───────────────────────────────────────────────────
# run  Claude Code writes are hard-restricted to:
#        infrastructure/characters/
#        infrastructure/dialogues/
#        infrastructure/queue/queue.json
# dev  no restrictions
TAVERN_MODE=run

# ─── Tavern planner model ───────────────────────────────────────────────────
# sonnet
# haiku
TAVERN_PLANNER=haiku

# ─── Tavern turns strategy ───────────────────────────────────────────────────
# sequential  Default. Turns dispatched in order, each reads prior turns' prose.
# parallel    Deprecated — ignored. Sequential is forced regardless.
TAVERN_TURNS=sequential

# ─── Player character mode ───────────────────────────────────────────────────
# off  Default. Director mode — all characters are AI-generated.
#      User gives scene direction but never speaks as a character.
# on   Player mode — one character is the player. Player types that
#      character's dialogue in the UI. AI generates all other characters.
#      characters.json must have a player_id field when this is on.
TAVERN_VERBATIM=off

# ─── Tavern chat mode ───────────────────────────────────────────────────
# normal    Standard prose mode — characters write full turns (speech + actions)
# narrator  Narrator mode — characters ONLY speak, a neutral narrator handles
#           all physical actions/descriptions. Variable-length rounds: NPCs
#           converse freely until player input is needed. Goals replace scenarios.
TAVERN_CHAT_MODE=normal

# ─── Narrator voice (only when TAVERN_CHAT_MODE=narrator) ───────────────
# neutral   Clean, transparent, minimal — reports what happens without style
# literary  Slightly more descriptive, atmospheric — adapts to scene mood
TAVERN_NARRATOR_VOICE=neutral

# ─── Voice engine ─────────────────────────────────────────────────────────────
# off     TTS disabled
# kokoro  Kokoro (default — broader voice selection)
# xtts    XTTS v2
VITE_VOICE_ENGINE=off

# API base URL for the active voice engine (ignored when VITE_VOICE_ENGINE=off)
VITE_VOICE_ENGINE_URL=http://localhost:8880
