# ─── Tavern operation mode ───────────────────────────────────────────────────
# run  Claude Code writes are hard-restricted to:
#        infrastructure/characters/
#        infrastructure/dialogues/
#        infrastructure/queue/queue.json
# dev  no restrictions
TAVERN_MODE=run

# ─── Tavern planner model ───────────────────────────────────────────────────
# sonnet
# haiku
TAVERN_PLANNER=haiku

# ─── Tavern turns strategy ───────────────────────────────────────────────────
# sequential
# parallel
TAVERN_TURNS=parallel

# ─── Tavern chat mode ───────────────────────────────────────────────────
# normal
# rpg       no rollbacks, better accounting for RPG stats
TAVERN_CHAT_MODE=normal

# ─── Voice engine ─────────────────────────────────────────────────────────────
# off     TTS disabled
# kokoro  Kokoro (default — broader voice selection)
# xtts    XTTS v2
VITE_VOICE_ENGINE=off

# API base URL for the active voice engine (ignored when VITE_VOICE_ENGINE=off)
VITE_VOICE_ENGINE_URL=http://localhost:8880
